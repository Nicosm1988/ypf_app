{
  "name": "ypf-bi-playbook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portal interno de Datalización YPF para automatizar procesos con PRD, Spec, roadmap, diccionario, BI/Fabric, librerías y atajos.",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "docs:modelos": "node scripts/generate-docx-models.mjs",
    "build": "node scripts/generate-docx-models.mjs && node scripts/validate-build.mjs",
    "validate": "node scripts/generate-docx-models.mjs && node scripts/validate-build.mjs",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run lint:md",
    "lint:js": "eslint app.js data/**/*.js scripts/**/*.mjs service-worker.js",
    "lint:css": "stylelint styles.css",
    "lint:html": "html-validate index.html",
    "lint:md": "markdownlint README.md docs/**/*.md .codex/**/*.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "qa:install-browsers": "playwright install chromium",
    "qa:e2e": "node scripts/qa-playwright.mjs",
    "qa:agents": "node scripts/validate-agent-system.mjs",
    "qa:links": "node scripts/check-local-links.mjs",
    "quality": "npm run build && npm run lint && npm run qa:agents && npm run qa:links && npm run qa:e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "docx": "9.7.1",
    "eslint": "10.5.0",
    "globals": "17.7.0",
    "html-validate": "11.5.3",
    "markdownlint-cli": "0.49.0",
    "playwright": "1.61.1",
    "prettier": "3.8.4",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0"
  }
}
